# OS junk
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Node
node_modules/
npm-debug.log*
package-lock.json

# Dev/scratch artifacts. NOTE: as of v1.2.0 the app is split into
# index.html + styles.css + app.js (all tracked). app.js is intentionally
# NOT ignored; the patterns below only catch old scratch/build files.
shell.html
func*.js
smoke*.js
pourover-v*.html

# Capacitor native build output
pourcast-ios/ios/App/build/
pourcast-ios/ios/App/output/
DerivedData/
*.xcuserstate
xcuserdata/

# Env / secrets (never commit these)
.env
.env.*
*.pem
*.key

# NOTE: brewer icon PNGs are intentionally NOT ignored.
# They are the only copies of the source art; index.html embeds them as base64,
# so the loose .png files are the editable originals worth keeping in history.
